# ── LLM Providers ──────────────────────────────────────────────────────────────
# Fill in the providers you want to use. Others can be left blank.
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Brave Search MCP (for knowledge feed)
BRAVE_API_KEY=BSA...

# GitHub MCP
GITHUB_TOKEN=ghp_...

# ── Database (Supabase) ────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
# Used by LangGraph Postgres checkpointer (graph.checkpointer = "postgres")
SUPABASE_DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Notification Integrations ──────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SENDGRID_API_KEY=SG...

# Firebase push notifications
FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
FIREBASE_PROJECT_ID=your-project-id

# ── Google Calendar ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# ── Auth ────────────────────────────────────────────────────────────────────────
# Used when security.auth_mode = "api_key"
API_KEYS=dev-key-1,dev-key-2

# Used when security.auth_mode = "clerk"
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── Environment ────────────────────────────────────────────────────────────────
# Overrides app.environment in config.yaml
ENVIRONMENT=development
